FROM public.ecr.aws/lambda/python:3.11

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG NN_WEIGHTS_DRIVE_FOLDER_URL="https://drive.google.com/drive/folders/1uq5C9edPIZ1973dArZiEO-VE13F7m8MK?usp=drive_link"

COPY requirements.lambda.txt .
RUN pip install --no-cache-dir --only-binary=:all: -r requirements.lambda.txt --target "${LAMBDA_TASK_ROOT}" && \
    pip install --no-cache-dir --only-binary=:all: --index-url https://download.pytorch.org/whl/cpu torch==2.3.1 --target "${LAMBDA_TASK_ROOT}" && \
    pip install --no-cache-dir gdown

RUN mkdir -p /tmp/nn_weights && \
    gdown --folder "${NN_WEIGHTS_DRIVE_FOLDER_URL}" -O /tmp/nn_weights && \
    MODEL_FILE="$(find /tmp/nn_weights -type f -name '*.pth' | head -n 1)" && \
    test -n "${MODEL_FILE}" && \
    cp "${MODEL_FILE}" "${LAMBDA_TASK_ROOT}/deep_neural_network_model.bin" && \
    rm -rf /tmp/nn_weights

COPY deep_neural_network.py "${LAMBDA_TASK_ROOT}/"
COPY inference_service.py "${LAMBDA_TASK_ROOT}/"
COPY lambda_handler.py "${LAMBDA_TASK_ROOT}/"

CMD ["lambda_handler.lambda_handler"]
